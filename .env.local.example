# OpenRouter API key — get one at https://openrouter.ai/keys
# AI email generation is optional; if unset the game falls back to curated templates.
VITE_OPENROUTER_API_KEY=

# OpenRouter model slug. Defaults to Llama 3.3 70B (free).
VITE_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Supabase — required for the global leaderboard.
# Project URL and anon (public) key from Supabase → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
